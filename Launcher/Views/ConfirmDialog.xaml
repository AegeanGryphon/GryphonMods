<Window x:Class="Launcher.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="340"
        Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Effect>
        <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.75"/>
    </Window.Effect>

    <Border CornerRadius="10"
            Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            ClipToBounds="True"
            Padding="24,20,24,20">
        <StackPanel>

            <!-- Title -->
            <TextBlock x:Name="TxtTitle"
                       Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <!-- Message -->
            <TextBlock x:Name="TxtMessage"
                       Foreground="{StaticResource BrushTextMuted}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BtnNo"
                        Content="Cancel"
                        Style="{StaticResource BtnSecondary}"
                        Height="32"
                        Padding="16,0"
                        FontSize="12"
                        Click="BtnNo_Click"/>
                <Button x:Name="BtnYes"
                        Content="Delete"
                        Style="{StaticResource BtnDanger}"
                        Height="32"
                        Margin="8,0,0,0"
                        Click="BtnYes_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
