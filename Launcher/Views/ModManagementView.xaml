<UserControl x:Class="Launcher.Views.ModManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: back bar -->
            <RowDefinition Height="46"/>
            <!-- Row 1: unified mod list -->
            <RowDefinition Height="*"/>
            <!-- Row 2: status text -->
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════ ROW 0: Back bar ═══════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Button x:Name="BtnBack"
                        Content="← Back"
                        Style="{StaticResource BtnChrome}"
                        Width="Auto"
                        Padding="8,0"
                        HorizontalAlignment="Left"
                        Click="BtnBack_Click"/>

                <TextBlock Text="MOD MANAGEMENT"
                           Foreground="{StaticResource BrushTextMuted}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button x:Name="BtnRefresh"
                        Content="↻ Refresh"
                        Style="{StaticResource BtnChrome}"
                        Width="Auto"
                        Padding="8,0"
                        HorizontalAlignment="Right"
                        Click="BtnRefresh_Click"/>
            </Grid>
        </Border>

        <!-- ═══════════════ ROW 1: Unified mod list ═══════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,12,16,12">
            <StackPanel x:Name="ModList"/>
        </ScrollViewer>

        <!-- ═══════════════ ROW 2: Status ═══════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="14,0">
            <TextBlock x:Name="TxtStatus"
                       Text="Ready."
                       Foreground="{StaticResource BrushTextMuted}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
